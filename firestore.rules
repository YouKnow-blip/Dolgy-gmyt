rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- VALIDATION BLUEPRINTS ---

    // Validates Task structure
    function isValidTask(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'description', 'status', 'priority', 'color', 'posX', 'posY', 'pinned', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 18
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 1500
        && data.status is string && (data.status == 'pending' || data.status == 'completed')
        && data.priority is string && (data.priority == 'low' || data.priority == 'medium' || data.priority == 'high')
        && data.color is string && data.color.size() <= 100
        && (data.posX is int || data.posX is float)
        && (data.posY is int || data.posY is float)
        && data.pinned is bool
        && data.createdAt is string && data.createdAt.size() <= 50
        && data.updatedAt is string && data.updatedAt.size() <= 50
        && (!data.keys().hasAny(['reminderTime']) || (data.reminderTime is string && data.reminderTime.size() <= 128))
        && (!data.keys().hasAny(['attachedImage']) || data.attachedImage is string)
        && (!data.keys().hasAny(['attachedAudio']) || data.attachedAudio is string)
        && (!data.keys().hasAny(['attachedAudioName']) || (data.attachedAudioName is string && data.attachedAudioName.size() <= 300))
        && (!data.keys().hasAny(['attachedLink']) || (data.attachedLink is string && data.attachedLink.size() <= 1000));
    }

    // Validates Board Drawing structure
    function isValidDrawing(data) {
      return data.keys().hasAll(['id', 'userId', 'strokesData', 'updatedAt'])
        && data.keys().size() == 4
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId == request.auth.uid
        && data.strokesData is string && data.strokesData.size() <= 1048576 // Limits size of drawing lines to ~1MB
        && data.updatedAt is string && data.updatedAt.size() <= 50;
    }

    // Validates Board Settings structure
    function isValidSettings(data) {
      return data.keys().hasAll(['id', 'userId', 'theme', 'showGrid', 'panX', 'panY', 'zoom', 'updatedAt'])
        && data.keys().size() == 8
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId == request.auth.uid
        && data.theme is string && (data.theme == 'dark' || data.theme == 'light')
        && data.showGrid is bool
        && (data.panX is int || data.panX is float)
        && (data.panY is int || data.panY is float)
        && (data.zoom is int || data.zoom is float)
        && data.updatedAt is string && data.updatedAt.size() <= 50;
    }


    // --- SECURITY ACCESS CONTROLS ---

    // Tasks collection security
    match /users/{userId}/tasks/{taskId} {
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId)
                    && isValidId(taskId)
                    && isValidTask(incoming());
                    
      allow update: if isOwner(userId)
                    && isValidId(taskId)
                    && isValidTask(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().id == existing().id;
                    
      allow delete: if isOwner(userId);
    }

    // Board Drawing collection security
    match /users/{userId}/drawings/{drawingId} {
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId)
                    && isValidId(drawingId)
                    && isValidDrawing(incoming());
                    
      allow update: if isOwner(userId)
                    && isValidId(drawingId)
                    && isValidDrawing(incoming())
                    && incoming().id == existing().id;
                    
      allow delete: if isOwner(userId);
    }

    // Board Settings collection security
    match /users/{userId}/settings/{settingsId} {
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId)
                    && isValidId(settingsId)
                    && isValidSettings(incoming());
                    
      allow update: if isOwner(userId)
                    && isValidId(settingsId)
                    && isValidSettings(incoming())
                    && incoming().id == existing().id;
                    
      allow delete: if isOwner(userId);
    }
  }
}
